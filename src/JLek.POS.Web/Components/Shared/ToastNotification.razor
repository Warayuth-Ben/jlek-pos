@namespace JLek.POS.Web.Components.Shared

<div class="toast-container" @attributes="AdditionalAttributes">
    @if (IsVisible)
    {
        <div class="toast toast-@Type.ToString().ToLower()" 
             role="status" 
             aria-live="polite"
             tabindex="-1"
             @onclick="Dismiss">
            <span class="toast-icon">
                @(Type switch
                {
                    ToastType.Success => "✓",
                    ToastType.Error => "✕",
                    ToastType.Warning => "⚠",
                    ToastType.Info => "ℹ",
                    _ => ""
                })
            </span>
            <span class="toast-message">@Message</span>
            <button class="toast-dismiss" @onclick="Dismiss" aria-label="Dismiss notification">&times;</button>
        </div>
    }
</div>

@code {
    [Parameter] public ToastType Type { get; set; } = ToastType.Info;
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public int DurationMs { get; set; } = 3000;
    [Parameter] public EventCallback OnDismiss { get; set; }
    [Parameter] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private Timer? _timer;

    protected override void OnParametersSet()
    {
        _timer?.Dispose();
        if (IsVisible && DurationMs > 0)
        {
            _timer = new Timer(async _ =>
            {
                await InvokeAsync(async () =>
                {
                    await OnDismiss.InvokeAsync();
                    StateHasChanged();
                });
            }, null, DurationMs, Timeout.Infinite);
        }
    }

    private async Task Dismiss()
    {
        _timer?.Dispose();
        await OnDismiss.InvokeAsync();
    }

    public void Dispose() => _timer?.Dispose();
}

public enum ToastType
{
    Success,
    Error,
    Warning,
    Info
}