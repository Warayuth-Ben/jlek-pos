@namespace JLek.POS.Web.Components.Cashier.Menu
@using JLek.POS.Web.Presentation.Models

<Panel Header="Menu">
    <div class="menu-panel">
        <div class="menu-panel__toolbar">
            <SearchBox Placeholder="Search" Disabled="true" />
            <button class="menu-panel__category-btn" disabled title="Category">
                Category &#9660;
            </button>
        </div>

        <div class="menu-panel__body">
            <MenuGrid Items="Items" OnSelected="@HandleMenuSelected" />
        </div>
    </div>
</Panel>

@code {
    [Parameter]
    public IReadOnlyList<MenuItemViewModel> Items { get; set; } = Array.Empty<MenuItemViewModel>();

    [Parameter]
    public EventCallback<MenuItemViewModel> OnMenuItemSelected { get; set; }

    private void HandleMenuSelected(Guid menuId)
    {
        var selected = Items.FirstOrDefault(x => x.Id == menuId);
        if (selected is not null)
        {
            OnMenuItemSelected.InvokeAsync(selected);
        }
    }
}
