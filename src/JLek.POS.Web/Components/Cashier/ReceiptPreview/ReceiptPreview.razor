@using JLek.POS.Web.Contracts.Orders

@if (!Show)
{
    return;
}

<div class="receipt-preview-overlay" @onclick="HandleCancel">
    <div class="receipt-preview" @onclick:stopPropagation="true">
        <div class="receipt-preview-header">
            <h3>Receipt Preview</h3>
            <button class="btn-close" @onclick="HandleCancel">X</button>
        </div>
        <div class="receipt-preview-body">
            <div class="receipt-store-name">JLek POS</div>
            <div class="receipt-divider">========================</div>
            <div class="receipt-order-id">Order: @Order?.Id</div>
            <div class="receipt-divider">------------------------</div>

            @if (Order is not null)
            {
                @foreach (var item in Order.Items)
                {
                    <div class="receipt-item">
                        <div class="receipt-item-name">@GetProductName(item.MenuItemId)</div>
                        <div class="receipt-item-detail">
                            <span>@item.Quantity x @item.UnitPrice</span>
                            <span class="receipt-item-total">@item.TotalPrice</span>
                        </div>
                    </div>
                }
            }

            <div class="receipt-divider">------------------------</div>
            <div class="receipt-total">
                <span>Total</span>
                <span class="receipt-total-amount">@Order?.Total</span>
            </div>
            <div class="receipt-divider">========================</div>
            <div class="receipt-footer">
                <span>Thank you!</span>
            </div>
        </div>
        <div class="receipt-preview-actions">
            <button class="btn-print" @onclick="HandlePrint">Print</button>
            <button class="btn-cancel" @onclick="HandleCancel">Close</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public OrderResponse? Order { get; set; }
    [Parameter] public Dictionary<Guid, string> ProductNames { get; set; } = [];
    [Parameter] public EventCallback OnPrint { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task HandlePrint()
    {
        await OnPrint.InvokeAsync();
    }

    private async Task HandleCancel()
    {
        await OnCancel.InvokeAsync();
    }

    private string GetProductName(Guid menuItemId)
    {
        return ProductNames.TryGetValue(menuItemId, out var name)
            ? name
            : menuItemId.ToString();
    }
}