@inherits LayoutComponentBase

<div class="pos-shell">
    <aside class="pos-rail" aria-label="Primary navigation">
        <NavMenu />
    </aside>

    <main class="pos-main">
        <header class="pos-topbar">
            <div>
                <div class="pos-kicker">Service floor</div>
                <div class="pos-title">JLek POS</div>
            </div>
            <div class="pos-topbar-actions">
                <span class="pos-live-dot" aria-hidden="true"></span>
                <span>Online</span>
                <button class="icon-button" title="Notifications" aria-label="Notifications">B</button>
                <button class="profile-button" title="Current user">ST</button>
            </div>
        </header>

        <section class="pos-content">
            @Body
        </section>
    </main>
</div>
