@page "/kitchen"

<PageTitle>Kitchen</PageTitle>

<section class="workspace-page kitchen-redesign">
    <div class="workspace-heading">
        <div>
            <p class="eyebrow">Kitchen workspace</p>
            <h1>Production queue</h1>
        </div>
        <button class="secondary-action" @onclick="AddTicket">New ticket</button>
    </div>

    <div class="kanban-grid">
        @foreach (var status in _statuses)
        {
            <section class="queue-column">
                <div class="panel-header">
                    <h2>@status</h2>
                    <span>@_tickets.Count(t => t.Status == status)</span>
                </div>
                @foreach (var ticket in _tickets.Where(t => t.Status == status))
                {
                    <article class="ticket-card @status.ToLowerInvariant()">
                        <div class="ticket-top">
                            <strong>#@ticket.Number</strong>
                            <span>@ticket.Elapsed min</span>
                        </div>
                        <ul>
                            @foreach (var item in ticket.Items)
                            {
                                <li>@item</li>
                            }
                        </ul>
                        <button class="ticket-action" @onclick="@(() => Advance(ticket))">@NextAction(ticket.Status)</button>
                    </article>
                }
            </section>
        }
    </div>
</section>

@code {
    private readonly string[] _statuses = ["Pending", "Preparing", "Ready"];
    private readonly List<Ticket> _tickets =
    [
        new(24, "Pending", 4, ["2x Pad Thai", "1x Thai Tea"]),
        new(25, "Preparing", 11, ["1x Tom Yum", "2x Rice"]),
        new(26, "Ready", 16, ["3x Fried Rice"]),
        new(27, "Pending", 2, ["1x Mango Sticky Rice"])
    ];

    private void Advance(Ticket ticket)
    {
        ticket.Status = ticket.Status switch
        {
            "Pending" => "Preparing",
            "Preparing" => "Ready",
            _ => "Served"
        };
        if (ticket.Status == "Served") _tickets.Remove(ticket);
    }

    private void AddTicket() => _tickets.Insert(0, new Ticket(28 + _tickets.Count, "Pending", 0, ["1x Chef special"]));
    private static string NextAction(string status) => status switch
    {
        "Pending" => "Start",
        "Preparing" => "Mark ready",
        _ => "Serve"
    };

    private sealed class Ticket(int number, string status, int elapsed, string[] items)
    {
        public int Number { get; } = number;
        public string Status { get; set; } = status;
        public int Elapsed { get; } = elapsed;
        public string[] Items { get; } = items;
    }
}
