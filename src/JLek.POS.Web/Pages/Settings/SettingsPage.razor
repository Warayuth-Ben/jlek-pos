@page "/settings"

<PageTitle>Settings</PageTitle>

<section class="workspace-page settings-redesign">
    <div class="workspace-heading">
        <div>
            <p class="eyebrow">Settings workspace</p>
            <h1>Store configuration</h1>
        </div>
        <button class="primary-action" @onclick="Save">Save</button>
    </div>

    <div class="settings-grid">
        <section class="surface-panel settings-form">
            <div class="panel-header"><h2>General</h2><span>@_saved</span></div>
            <label>Shop name<input @bind="_shopName" /></label>
            <label>Language
                <select @bind="_language">
                    <option value="th">Thai</option>
                    <option value="en">English</option>
                </select>
            </label>
            <label>Refresh interval <input type="range" min="5" max="60" step="5" @bind="_refresh" /></label>
            <div class="range-readout">@_refresh seconds</div>
        </section>

        <section class="surface-panel settings-form">
            <div class="panel-header"><h2>Printer</h2><span>Local</span></div>
            <label>Printer type
                <select @bind="_printer">
                    <option>None</option>
                    <option>USB thermal</option>
                    <option>Network thermal</option>
                </select>
            </label>
            <label>Paper width
                <select @bind="_paper">
                    <option>58 mm</option>
                    <option>80 mm</option>
                </select>
            </label>
            <label class="toggle-row"><span>Auto print kitchen ticket</span><input type="checkbox" @bind="_autoPrint" /></label>
        </section>
    </div>
</section>

@code {
    private string _shopName = "JLek Restaurant";
    private string _language = "th";
    private int _refresh = 15;
    private string _printer = "None";
    private string _paper = "58 mm";
    private bool _autoPrint = true;
    private string _saved = "Unsaved";
    private void Save() => _saved = "Saved";
}
