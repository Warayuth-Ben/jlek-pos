@page "/dashboard"
@using System.Globalization

<PageTitle>Dashboard</PageTitle>

<section class="workspace-page dashboard-redesign">
    <PageHeader Title="Live operations" Kicker="Manager workspace">
        <Actions>
            <button class="secondary-action" @onclick="Refresh">Refresh</button>
        </Actions>
    </PageHeader>

    <div class="metric-strip">
        <div class="metric-tile"><span>Net sales</span><strong>@Format(_sales)</strong></div>
        <div class="metric-tile"><span>Orders</span><strong>@_orders</strong></div>
        <div class="metric-tile"><span>Ready</span><strong>@_ready</strong></div>
        <div class="metric-tile"><span>Avg order</span><strong>@Format(_sales / Math.Max(_orders, 1))</strong></div>
    </div>

    <div class="dashboard-panels">
        <section class="surface-panel">
            <div class="panel-header"><h2>Best sellers</h2><span>Top 5</span></div>
            @foreach (var item in _bestSellers)
            {
                <div class="rank-row"><span>@item.Name</span><b>@item.Count</b></div>
            }
        </section>
        <section class="surface-panel">
            <div class="panel-header"><h2>Payment mix</h2><span>Today</span></div>
            @foreach (var item in _payments)
            {
                <div class="rank-row"><span>@item.Name</span><b>@Format(item.Amount)</b></div>
            }
        </section>
        <section class="surface-panel">
            <div class="panel-header"><h2>Recent orders</h2><span>Last 20 min</span></div>
            @foreach (var item in _recent)
            {
                <div class="rank-row"><span>#@item.Number @item.Status</span><b>@Format(item.Total)</b></div>
            }
        </section>
    </div>
</section>

@code {
    private decimal _sales = 18640;
    private int _orders = 54;
    private int _ready = 3;
    private readonly List<(string Name, int Count)> _bestSellers = [("Pad Thai", 31), ("Tom Yum", 22), ("Thai Tea", 20), ("Fried Rice", 18), ("Water", 16)];
    private readonly List<(string Name, decimal Amount)> _payments = [("Cash", 8420), ("PromptPay", 7760), ("Card", 2460)];
    private readonly List<(int Number, string Status, decimal Total)> _recent = [(1042, "Confirmed", 420), (1041, "Completed", 680), (1040, "Preparing", 310)];
    private void Refresh()
    {
        _sales += 240;
        _orders++;
        _ready = (_ready + 1) % 6;
    }
    private static string Format(decimal value) => value.ToString("C0", CultureInfo.GetCultureInfo("th-TH"));
}
