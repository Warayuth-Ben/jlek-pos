@page "/"

<PageTitle>JLek POS</PageTitle>

<section class="workspace-page home-workspace">
    <div class="workspace-hero">
        <div>
            <p class="eyebrow">Today at a glance</p>
            <h1>JLek POS</h1>
            <p class="hero-copy">A tablet-first operating surface for cashier, kitchen, and manager workflows.</p>
        </div>
        <a class="primary-action" href="cashier">Open Cashier</a>
    </div>

    <div class="metric-strip">
        <div class="metric-tile"><span>Open tables</span><strong>12</strong></div>
        <div class="metric-tile"><span>Active orders</span><strong>18</strong></div>
        <div class="metric-tile"><span>Preparing</span><strong>6</strong></div>
        <div class="metric-tile"><span>Ready</span><strong>3</strong></div>
    </div>

    <div class="workspace-grid home-launcher">
        <a class="launch-card" href="cashier"><b>Cashier</b><span>Tables, orders, payment</span></a>
        <a class="launch-card" href="kitchen"><b>Kitchen</b><span>Pending, preparing, ready</span></a>
        <a class="launch-card" href="dashboard"><b>Dashboard</b><span>Live operation pulse</span></a>
        <a class="launch-card" href="reports"><b>Reports</b><span>Sales and product movement</span></a>
        <a class="launch-card" href="settings"><b>Settings</b><span>Shop, printer, display</span></a>
    </div>
</section>
