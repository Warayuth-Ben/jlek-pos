@using JLek.POS.Web.Components.Cashier.TableGrid
@using JLek.POS.Web.Components.Cashier.OrderPanel
@using JLek.POS.Web.Components.Cashier.MenuModal
@using JLek.POS.Web.Components.Cashier.ReceiptPreview
@using JLek.POS.Web.Components.Shared
@using JLek.POS.Web.Clients.Orders
@using JLek.POS.Web.Clients.Tables
@inject IOrderClient OrderClient
@inject ITableClient TableClient
@inject ILogger<CashierWorkspace> Logger

<WorkspaceShell>
    <HeaderContent>
        <div class="cashier-header">
            <h2>Cashier Workspace</h2>
            <span class="connection-status">Ready</span>
        </div>
    </HeaderContent>
    <ToolbarContent>
        <button @onclick="RefreshTablesAsync" class="btn-secondary">⟳ Refresh</button>
    </ToolbarContent>
    <PrimaryContent>
        <TableGrid SelectedTableId="@_selectedTableId"
                   RefreshVersion="@_tableRefreshVersion"
                   OnTableSelected="HandleTableSelected"
                   OnDoubleClick="HandleTableDoubleClick" />
    </PrimaryContent>
    <SecondaryContent>
        <OrderPanel SelectedTableId="@_selectedTableId"
                    RefreshVersion="@_orderRefreshVersion"
                    OnTableOpened="HandleTableOperationComplete"
                    OnAddItemRequested="HandleAddItemRequested"
                    ProductNames="@_productNames" />
    </SecondaryContent>
    <StatusBarContent>
        <span>Online</span>
    </StatusBarContent>
</WorkspaceShell>

<MenuModal Show="@_isMenuOpen"
           OrderId="@(_activeOrderId ?? Guid.Empty)"
           OnProductAdded="HandleProductAdded"
           OnClose="HandleMenuClose" />

<ToastNotification Type="@_toastType"
                   Message="@_toastMessage"
                   IsVisible="@_showToast"
                   OnDismiss="HandleToastDismiss" />

@code {
    private Guid? _selectedTableId;
    private Guid? _activeOrderId;
    private int _tableRefreshVersion;
    private int _orderRefreshVersion;
    private bool _isMenuOpen;
    private bool _isAddingItem;
    private bool _showToast;
    private string _toastMessage = "";
    private ToastType _toastType = ToastType.Info;
    private Dictionary<Guid, string> _productNames = [];

    private void HandleTableSelected(Guid? tableId)
    {
        _selectedTableId = tableId;
        _activeOrderId = null;
        _orderRefreshVersion++;
    }

    private void HandleTableDoubleClick(Guid tableId)
    {
        _selectedTableId = tableId;
        _orderRefreshVersion++;
    }

    private void HandleTableOperationComplete()
    {
        _tableRefreshVersion++;
        _selectedTableId = null;
        _activeOrderId = null;
        _orderRefreshVersion++;
    }

    private void HandleAddItemRequested(Guid orderId)
    {
        _activeOrderId = orderId;
        _isMenuOpen = true;
    }

    private async Task HandleProductAdded(Guid productId)
    {
        if (_isAddingItem || !_activeOrderId.HasValue) return;
        _isAddingItem = true;
        try
        {
            await OrderClient.AddItemAsync(_activeOrderId.Value, productId, 1, 0);
            _orderRefreshVersion++;
            ShowToast(ToastType.Success, "✓ Item added");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Cannot add item");
            ShowToast(ToastType.Error, "Cannot add item");
        }
        finally { _isAddingItem = false; }
    }

    private void HandleMenuClose() => _isMenuOpen = false;

    private void RefreshTablesAsync() => _tableRefreshVersion++;

    private void ShowToast(ToastType type, string message)
    {
        _toastType = type; _toastMessage = message; _showToast = true;
    }

    private void HandleToastDismiss() => _showToast = false;
}