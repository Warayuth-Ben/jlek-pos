@page "/cashier"
@using System.Globalization

<PageTitle>Cashier</PageTitle>

<section class="workspace-page cashier-redesign">
    <PageHeader Title="Floor service" Kicker="Cashier workspace">
        <Actions>
            <SegmentedControl AriaLabel="Service mode"
                              Items="@_modeItems"
                              OnSelect="@HandleModeChange" />
        </Actions>
    </PageHeader>

    <div class="cashier-layout">
        <section class="surface-panel table-map">
            <div class="panel-header">
                <h2>Tables</h2>
                <span>@OccupiedCount occupied</span>
            </div>
            <div class="table-grid-redesign">
                @foreach (var table in _tables)
                {
                    <button class="table-tile @TableClass(table)" @onclick="@(() => SelectTable(table.Id))">
                        <span>@table.Name</span>
                        <strong>@table.Status</strong>
                        <small>@(table.Total == 0 ? "Ready" : Format(table.Total))</small>
                    </button>
                }
            </div>
        </section>

        <section class="surface-panel order-builder">
            <div class="panel-header">
                <h2>@SelectedTable.Name</h2>
                <span class="state-pill @SelectedTable.Status.ToLowerInvariant()">@SelectedTable.Status</span>
            </div>

            <div class="menu-chips">
                @foreach (var item in _menu)
                {
                    <button @onclick="@(() => AddItem(item))">
                        <span>@item.Name</span>
                        <strong>@Format(item.Price)</strong>
                    </button>
                }
            </div>

            <div class="order-lines">
                @if (_order.Count == 0)
                {
                    <EmptyState>Select menu items to start this order.</EmptyState>
                }
                @foreach (var item in _order)
                {
                    <OrderLineItem Name="@item.Name"
                                   Quantity="@item.Quantity"
                                   Total="@Format(item.Price * item.Quantity)"
                                   OnDecrease="@(() => Decrease(item.Name))"
                                   OnIncrease="@(() => AddItem(new MenuItem(item.Name, item.Price)))" />
                }
            </div>

            <div class="bill-dock">
                <div><span>Total</span><strong>@Format(OrderTotal)</strong></div>
                <button class="secondary-action" disabled="@(_order.Count == 0)" @onclick="ConfirmOrder">Confirm</button>
                <button class="primary-action" disabled="@(_order.Count == 0)" @onclick="Pay">Pay</button>
            </div>
        </section>
    </div>

    @if (!string.IsNullOrWhiteSpace(_toast))
    {
        <div class="toast-card">@_toast</div>
    }
</section>

@code {
    private string _mode = "Dine in";
    private int _selectedTableId = 2;
    private string? _toast;
    private readonly List<TableModel> _tables =
    [
        new(1, "A1", "Available", 0), new(2, "A2", "Occupied", 640),
        new(3, "A3", "Occupied", 420), new(4, "A4", "Available", 0),
        new(5, "B1", "Occupied", 980), new(6, "B2", "Available", 0),
        new(7, "B3", "Occupied", 310), new(8, "B4", "Available", 0)
    ];
    private readonly List<MenuItem> _menu =
    [
        new("Pad Thai", 120), new("Tom Yum", 180), new("Fried Rice", 95),
        new("Thai Tea", 55), new("Mango Sticky Rice", 140), new("Water", 20)
    ];
    private readonly List<OrderItem> _order = [new("Pad Thai", 120, 2), new("Thai Tea", 55, 2)];

    private TableModel SelectedTable => _tables.First(t => t.Id == _selectedTableId);
    private int OccupiedCount => _tables.Count(t => t.Status == "Occupied");
    private decimal OrderTotal => _order.Sum(i => i.Price * i.Quantity);
    private string TableClass(TableModel table) => $"{table.Status.ToLowerInvariant()} {(table.Id == _selectedTableId ? "selected" : "")}";
    private static string Format(decimal value) => value.ToString("C0", CultureInfo.GetCultureInfo("th-TH"));
    private void SelectTable(int id) => _selectedTableId = id;
    private void AddItem(MenuItem item)
    {
        var existing = _order.FirstOrDefault(i => i.Name == item.Name);
        if (existing is null) _order.Add(new OrderItem(item.Name, item.Price, 1));
        else existing.Quantity++;
    }
    private void Decrease(string name)
    {
        var existing = _order.FirstOrDefault(i => i.Name == name);
        if (existing is null) return;
        existing.Quantity--;
        if (existing.Quantity <= 0) _order.Remove(existing);
    }
    private void ConfirmOrder() => _toast = $"Order for {SelectedTable.Name} confirmed.";
    private void Pay()
    {
        _toast = $"Payment received: {Format(OrderTotal)}";
        _order.Clear();
    }

    private List<SegmentedControl.SegmentItem> _modeItems => new()
    {
        new() { Label = "Dine in", Value = "Dine in", IsActive = _mode == "Dine in" },
        new() { Label = "Takeaway", Value = "Takeaway", IsActive = _mode == "Takeaway" },
        new() { Label = "Delivery", Value = "Delivery", IsActive = _mode == "Delivery" },
    };

    private void HandleModeChange(string mode) => _mode = mode;

    private record TableModel(int Id, string Name, string Status, decimal Total);
    private record MenuItem(string Name, decimal Price);
    private sealed class OrderItem(string name, decimal price, int quantity)
    {
        public string Name { get; } = name;
        public decimal Price { get; } = price;
        public int Quantity { get; set; } = quantity;
    }
}