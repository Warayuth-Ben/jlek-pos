@page "/reports"
@using System.Globalization

<PageTitle>Reports</PageTitle>

<section class="workspace-page reports-redesign">
    <div class="workspace-heading">
        <div>
            <p class="eyebrow">Reports workspace</p>
            <h1>Sales analysis</h1>
        </div>
        <input class="date-input" type="date" @bind="_date" />
    </div>

    <div class="segmented-control report-tabs">
        <button class="@TabClass("Daily")" @onclick="@(() => _tab = "Daily")">Daily</button>
        <button class="@TabClass("Payment")" @onclick="@(() => _tab = "Payment")">Payment</button>
        <button class="@TabClass("Best sellers")" @onclick="@(() => _tab = "Best sellers")">Best sellers</button>
    </div>

    <section class="surface-panel report-canvas">
        <div class="panel-header"><h2>@_tab</h2><span>@_date.ToString("yyyy-MM-dd")</span></div>
        @if (_tab == "Daily")
        {
            <div class="metric-strip">
                <div class="metric-tile"><span>Revenue</span><strong>@Format(12880)</strong></div>
                <div class="metric-tile"><span>Orders</span><strong>38</strong></div>
                <div class="metric-tile"><span>Items</span><strong>117</strong></div>
            </div>
        }
        else if (_tab == "Payment")
        {
            @foreach (var row in _payments)
            {
                <div class="rank-row"><span>@row.Name</span><b>@Format(row.Amount)</b></div>
            }
        }
        else
        {
            @foreach (var row in _items)
            {
                <div class="rank-row"><span>@row.Name</span><b>@row.Count sold</b></div>
            }
        }
    </section>
</section>

@code {
    private string _tab = "Daily";
    private DateTime _date = DateTime.Today;
    private readonly List<(string Name, decimal Amount)> _payments = [("PromptPay", 6840), ("Cash", 4390), ("Card", 1650)];
    private readonly List<(string Name, int Count)> _items = [("Pad Thai", 31), ("Tom Yum", 22), ("Thai Tea", 20), ("Fried Rice", 18)];
    private string TabClass(string tab) => _tab == tab ? "active" : "";
    private static string Format(decimal value) => value.ToString("C0", CultureInfo.GetCultureInfo("th-TH"));
}
